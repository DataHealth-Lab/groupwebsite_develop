ggplot(puzzle_data, aes(x, y)) +
# Puzzle pieces (with rounded tabs)
geom_tile(aes(fill = color), color = "white",
width = 0.85, height = 0.85, alpha = 0.8, linewidth = 1) +
# Labels (with HTML styling)
geom_richtext(aes(label = paste(icon, "<br>", label)),
fill = NA, label.color = NA, size = 3.5,
color = "black", fontface = "bold") +
# Customize
scale_fill_identity() + # Use colors from data
coord_fixed() +
theme_void() +
theme(plot.margin = margin(1, 1, 1, 1, "cm")) +
labs(title = "Research Domains")
load.emojifont('OpenSansEmoji.ttf') # Install via `install.packages("emojifont")`
# Define puzzle data
puzzle_data <- data.frame(
x = rep(1:3, each = 3),
y = rep(3:1, times = 3),
label = c("Epidemiology", "Data Science", "Biostatistics",
"Causal Inference", "RCTs", "AI", # Emoji icon for AI
"Public Health", "Implementation Science", "Global Health"),
icon = c("🦠", "📊", "📈", # Using emoji icons
"↔️", "⚖️", "🤖",
"🏥", "🔄", "🌍"),
color = rep(c("#E69F00", "#56B4E9", "#009E73"), 3) # Color-blind friendly
)
# Create plot
ggplot(puzzle_data, aes(x, y)) +
# Puzzle pieces (with rounded tabs)
geom_tile(aes(fill = color), color = "white",
width = 0.85, height = 0.85, alpha = 0.8, linewidth = 1) +
# Labels (with HTML styling)
geom_richtext(aes(label = paste(icon, "<br>", label)),
fill = NA, label.color = NA, size = 3.5,
color = "black", fontface = "bold") +
# Customize
scale_fill_identity() + # Use colors from data
coord_fixed() +
theme_void() +
theme(plot.margin = margin(1, 1, 1, 1, "cm")) +
labs(title = "Research Domains") +
# Optional: Add puzzle-like connectors
geom_segment(data = data.frame(x = c(1.9, 2.1, 2, 2),
aes(x = x, xend = x, y = c(1.9, 1.9, 1.9, 2.1)),
color = "white", linewidth = 2))
# Create plot
ggplot(puzzle_data, aes(x, y)) +
# Puzzle pieces (with rounded tabs)
geom_tile(aes(fill = color), color = "white",
width = 0.85, height = 0.85, alpha = 0.8, linewidth = 1) +
# Labels (with HTML styling)
geom_richtext(aes(label = paste(icon, "<br>", label)),
fill = NA, label.color = NA, size = 3.5,
color = "black", fontface = "bold") +
# Customize
scale_fill_identity() + # Use colors from data
coord_fixed() +
theme_void() +
theme(plot.margin = margin(1, 1, 1, 1, "cm")) +
labs(title = "Research Domains")
