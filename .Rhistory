fontface = "bold",
lineheight = 0.8  # Reduce space between lines
) +
scale_fill_identity() +
coord_fixed() +
theme_void() +
theme(plot.margin = margin(1, 1, 1, 1, "cm"))
library(tidyverse)
# Define puzzle data
puzzle_data <- data.frame(
x = rep(1:3, each = 3),
y = rep(3:1, times = 3),
label = c("Epidemiology", "Causal Inference", "Public Health",
"Data Science", "RCTs", "Implementation Science",
"Biostatistics", "AI", "Global Health"),
color = rep(c("#E69F00", "#56B4E9", "#009E73"), 3)
)
# Apply controlled line breaks (optional)
puzzle_data$label_wrapped <- str_wrap(puzzle_data$label, width = 10)  # Adjust width as needed
# Plot
ggplot(puzzle_data, aes(x, y)) +
geom_tile(aes(fill = color), color = "white",
width = 0.85, height = 0.85, alpha = 0.8, linewidth = 1) +
geom_richtext(
aes(label = label),  # Or use label_wrapped if using str_wrap
fill = NA,
label.color = NA,
size = 3.5,
color = "black",
fontface = "bold",
lineheight = 0.8  # Reduce space between lines
) +
scale_fill_identity() +
coord_fixed() +
theme_void() +
theme(plot.margin = margin(1, 1, 1, 1, "cm"))
